{# Секция слайдера товаров. Параметры: title (строка), products (массив объектов) #}
<section class="popular-products">
  <div class="container">

    <div class="popular-products__head">
      <h2 class="popular-products__title">{{ title }}</h2>
      <div class="popular-products__nav">
        <button class="pp-nav-btn pp-nav-btn--prev" type="button">
          <svg width="10" height="16" viewBox="0 0 10 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8.5 1.5L2 8L8.5 14.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="pp-nav-btn pp-nav-btn--next" type="button">
          <svg width="10" height="16" viewBox="0 0 10 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1.5 1.5L8 8L1.5 14.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="swiper pp-swiper">
      <div class="swiper-wrapper">
        {% for p in products %}
        <div class="swiper-slide">
          {% include "partials/product-card.twig" %}
        </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>
